# The @frachter-app scope (OPFS-VFS + SurrealDB fork packages) lives on GitHub
# Packages, not the public npm registry. NODE_AUTH_TOKEN must carry a token with
# `read:packages` for the frachter-app org (export it before install; set it as a
# Vercel build env var for deploys).
@frachter-app:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}
